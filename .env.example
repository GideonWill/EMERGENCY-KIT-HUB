# Optional: Express API (see server/.env). Enables login, checkout, appointments.
# Example: http://localhost:5000
VITE_API_URL=
VITE_DEMO_MODE=true
# Presentation mode: simulated login + checkout (no API/Stripe). Set false for production.
# VITE_DEMO_MODE=true

